# ===========================================
# TMA Platform - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# ===========================================
# Telegram Bot Configuration
# ===========================================
# Get your User ID from @userinfobot in Telegram
TELEGRAM_ADMIN_ID=

# Get Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=

# ===========================================
# Directus CMS Configuration
# ===========================================
# Directus URL (local development)
DIRECTUS_URL=http://localhost:8055

# Directus Admin Credentials (for setup script)
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=admin

# Directus Admin Token (get from Directus admin panel after setup)
# Settings -> API -> Admin Access Token
DIRECTUS_ADMIN_TOKEN=

# Directus Public Token (for frontend access)
# Create in Directus: Settings -> Roles -> Public -> Token
DIRECTUS_PUBLIC_TOKEN=

# ===========================================
# Database (for direct connection if needed)
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=directus
DB_USER=directus
DB_PASSWORD=directus_password

# ===========================================
# Next.js Application
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055

# Vercel Analytics (optional)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# ===========================================
# Security (change in production!)
# ===========================================
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=
